# Optional SharePoint workbench host used by imported SPFx apps.
SPFX_SERVE_TENANT_DOMAIN=contoso.sharepoint.com

# Lab defaults. Override when ports are busy.
SPFX_LAB_HOST=127.0.0.1
SPFX_LAB_PORT=5173

# Base CDN URL used by `npm run sync:cdn -- --app .spfx-kit/apps/<slug>`.
# Each app resolves to ${SPFX_KIT_CDN_BASE_URL}/<slug>/.
SPFX_KIT_CDN_BASE_URL=https://cdn.example.com/spfx
