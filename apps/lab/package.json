{
  "name": "@spfx-kit/lab",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local SPFx web part lab and SharePoint preview surface.",
  "scripts": {
    "dev": "vite --host ${SPFX_LAB_HOST:-127.0.0.1} --port ${SPFX_LAB_PORT:-5173}",
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.node.json && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@fluentui/react-components": "9.74.3",
    "@fluentui/react-icons": "2.0.331",
    "@hugeicons/core-free-icons": "4.2.2",
    "@hugeicons/react": "1.1.9",
    "@monaco-editor/react": "4.7.0",
    "@spfx-kit/code-workbench-runtime": "file:../../packages/code-workbench-runtime",
    "@spfx-kit/source-editor-core": "file:../../packages/source-editor-core",
    "@spfx-kit/spfx-lab-runtime": "file:../../packages/spfx-lab-runtime",
    "@tanstack/react-query": "4.44.0",
    "@tanstack/react-table": "8.21.3",
    "lucide-react": "1.23.0",
    "monaco-editor": "0.53.0",
    "react": "17.0.1",
    "react-dom": "17.0.1",
    "zod": "3.25.76",
    "zustand": "4.5.7"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "@types/react": "17.0.45",
    "@types/react-dom": "17.0.17",
    "@vitejs/plugin-react": "6.0.3",
    "typescript": "5.3.3",
    "vite": "8.1.3"
  },
  "optionalDependencies": {
    "@rolldown/binding-linux-arm64-gnu": "1.1.3",
    "@rolldown/binding-linux-x64-gnu": "1.1.3",
    "lightningcss-linux-arm64-gnu": "1.32.0",
    "lightningcss-linux-x64-gnu": "1.32.0"
  }
}
