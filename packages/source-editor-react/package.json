{
  "name": "@spfx-kit/source-editor-react",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "React 17-compatible inline and floating source editor with lazy Monaco loading.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@spfx-kit/source-editor-core": "file:../source-editor-core"
  },
  "peerDependencies": {
    "monaco-editor": ">=0.50.0 <1.0.0",
    "react": ">=17.0.0 <18.0.0",
    "react-dom": ">=17.0.0 <18.0.0"
  },
  "devDependencies": {
    "@types/react": "17.0.45",
    "@types/react-dom": "17.0.17",
    "monaco-editor": "0.53.0",
    "react": "17.0.1",
    "react-dom": "17.0.1",
    "typescript": "5.3.3"
  }
}
