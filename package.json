{
  "name": "spfx-kit",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.8",
  "description": "Monorepo for authoring, importing, previewing, and shipping SPFx applications and web parts.",
  "workspaces": [
    "apps/lab",
    "packages/*"
  ],
  "engines": {
    "node": ">=22.14.0 <23.0.0",
    "npm": ">=10.9.0 <11.0.0"
  },
  "scripts": {
    "dev": "npm run sync:lab && turbo run dev --filter @spfx-kit/lab",
    "build": "npm run sync:lab && turbo run build",
    "ship": "turbo run ship",
    "clean": "turbo run clean",
    "import:spfx": "node packages/spfx-tools/src/cli/import-spfx-app.mjs",
    "create:spfx": "node packages/spfx-tools/src/cli/create-spfx-app.mjs",
    "export:spfx": "node packages/spfx-tools/src/cli/export-spfx-app.mjs",
    "guard:public": "node packages/spfx-tools/src/cli/guard-public-repo.mjs",
    "sync:cdn": "node packages/spfx-tools/src/cli/sync-cdn-config.mjs",
    "sync:lab": "node packages/spfx-tools/src/cli/sync-lab.mjs",
    "validate:spfx": "node packages/spfx-tools/src/cli/validate-spfx-app.mjs"
  },
  "devDependencies": {
    "@microsoft/rush-stack-compiler-5.3": "0.1.0",
    "ajv": "8.20.0",
    "postcss": "8.5.15",
    "turbo": "2.10.0"
  }
}
